@page "{id:int}"
@model EduAI.Web.Pages.Chat.DetailsModel
@using EduAI.Model.Constants
@{ ViewData["Title"] = Model.ViewModel.Title; }

<div class="chat-layout eduai-chat"
     data-session-id="@Model.ViewModel.SessionId"
     data-subject-id="@Model.ViewModel.SubjectId"
     data-default-provider="@Model.ViewModel.DefaultProviderId"
     data-hub-url="/hubs/chat">

    <header class="eduai-chat-header">
        <div class="eduai-chat-header-main">
            <h1 class="eduai-chat-title">@Model.ViewModel.Title</h1>
            <p class="eduai-chat-subject">
                <span class="eduai-chat-subject-code">@Model.ViewModel.SubjectName</span>
            </p>
        </div>
        <div class="eduai-chat-header-actions">
            <div class="eduai-chat-model">
                <label class="visually-hidden" for="chat-provider">Model trả lời</label>
                <select class="form-select eduai-chat-model-select" id="chat-provider" name="ProviderId" aria-label="Model trả lời">
                    @foreach (var provider in Model.ViewModel.ProviderQuotaOverview.Providers)
                    {
                        if (provider.ProviderId == Model.ViewModel.DefaultProviderId && !provider.IsAvailable)
                        {
                            <option value="@provider.ProviderId" selected disabled>@provider.DisplayName - @provider.StatusText</option>
                        }
                        else if (provider.ProviderId == Model.ViewModel.DefaultProviderId)
                        {
                            <option value="@provider.ProviderId" selected>@provider.DisplayName - @provider.StatusText</option>
                        }
                        else if (!provider.IsAvailable)
                        {
                            <option value="@provider.ProviderId" disabled>@provider.DisplayName - @provider.StatusText</option>
                        }
                        else
                        {
                            <option value="@provider.ProviderId">@provider.DisplayName - @provider.StatusText</option>
                        }
                    }
                </select>
                <span id="chat-provider-help" class="visually-hidden">
                    @if (Model.ViewModel.ProviderQuotaOverview.Providers.Count == 0)
                    {
                        <text>Chưa có cấu hình model khả dụng.</text>
                    }
                    else
                    {
                        var defaultProvider = Model.ViewModel.ProviderQuotaOverview.Providers
                            .FirstOrDefault(p => p.ProviderId == Model.ViewModel.DefaultProviderId)
                            ?? Model.ViewModel.ProviderQuotaOverview.Providers[0];
                        <text>@defaultProvider.DisplayName: @defaultProvider.StatusText</text>
                    }
                </span>
            </div>
            <a asp-page="Index" class="btn eduai-chat-btn-outline" title="Lịch sử chat">
                <span class="eduai-chat-btn-icon" aria-hidden="true">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                </span>
                <span class="eduai-chat-btn-text">Lịch sử</span>
            </a>
            <a asp-page="Edit" asp-route-id="@Model.ViewModel.SessionId" class="btn eduai-chat-btn-outline" title="Cài đặt phiên">
                <span class="eduai-chat-btn-icon" aria-hidden="true">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M1 12h2M21 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4"/></svg>
                </span>
                <span class="eduai-chat-btn-text">Cài đặt</span>
            </a>
        </div>
    </header>

    <div id="chat-error" class="alert alert-danger eduai-chat-error @(string.IsNullOrEmpty(Model.ErrorMessage) ? "d-none" : "")" role="alert">
        @Model.ErrorMessage
    </div>

    <div class="eduai-chat-shell">
        <div id="chat-box" class="chat-box" role="log" aria-live="polite" aria-relevant="additions">
            @if (Model.ViewModel.Messages.Count == 0)
            {
                <div class="chat-empty">
                    <div class="chat-empty-title">Bắt đầu hội thoại</div>
                    <p class="chat-empty-text">Hỏi về tài liệu môn học — ví dụ “cung cấp tài liệu chapter 1” hoặc nội dung bài giảng.</p>
                </div>
            }
            @foreach (var m in Model.ViewModel.Messages)
            {
                var isUser = m.Role == "user";
                <div class="chat-message @(isUser ? "chat-user" : "chat-assistant")">
                    <div class="chat-avatar" aria-hidden="true">@(isUser ? "👤" : "🤖")</div>
                    <div class="chat-message-body">
                        <div class="chat-role">@(isUser ? "Bạn" : "EduAI")</div>
                        <div class="chat-bubble">
                            <div class="chat-text">@m.Content</div>
                            @if (!string.IsNullOrEmpty(m.Citations))
                            {
                                <div class="chat-citations">Nguồn: @m.Citations</div>
                            }
                        </div>
                    </div>
                </div>
            }
            <div id="chat-box-end" aria-hidden="true"></div>
        </div>

        <form class="chat-input-bar eduai-chat-composer-wrap" id="chat-form">
            <div class="eduai-chat-filter">
                <label class="eduai-chat-filter-label" for="chat-document">Lọc tài liệu</label>
                <select class="form-select eduai-chat-filter-select" id="chat-document" name="DocumentId" aria-label="Lọc tài liệu">
                    <option value="">Tất cả tài liệu</option>
                    @foreach (var doc in Model.ViewModel.Documents)
                    {
                        <option value="@doc.Id">@doc.FileName</option>
                    }
                </select>
                <span id="chat-document-help" class="eduai-chat-filter-hint">Có thể hỏi: “tài liệu chapter 1”</span>
            </div>

            <div class="eduai-chat-composer">
                <textarea class="form-control eduai-chat-input" id="chat-question" name="Question" rows="1"
                          placeholder="Hỏi về môn học này…"
                          autocomplete="off" required></textarea>
                <button type="submit" class="btn eduai-chat-send" id="chat-send-btn" aria-label="Gửi">
                    <svg class="eduai-chat-send-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M22 2L11 13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        <path d="M22 2L15 22l-4-9-9-4 20-7z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span class="chat-send-label">Gửi</span>
                </button>
            </div>

            <div class="form-text chat-status" id="chat-status" role="status" aria-live="polite">
                <span class="chat-status-pulse" aria-hidden="true"></span>
                <span class="chat-status-text">Đang kết nối…</span>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/chat-details.js" asp-append-version="true"></script>
}
